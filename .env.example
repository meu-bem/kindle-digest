# Reddit Configuration
SUBREDDITS=Gambiarra
POST_LIMIT_PER_SUBREDDIT=10
TOP_COMMENTS_PER_POST=10
MIN_SCORE=0
COMMENT_DEPTH=6
INCLUDE_NESTED_COMMENTS=True
USER_AGENT=kindle-digest-bot/1.0

# Image Settings
INCLUDE_IMAGES=True
DOWNLOAD_IMAGES=True

# Kindle optimization settings
KINDLE_IMAGE_WIDTH=600        # Default width for Kindle (pixels)
KINDLE_IMAGE_QUALITY=75       # JPEG quality (1-100, lower = smaller file)
KINDLE_MAX_IMAGE_SIZE_MB=0.5  # Max size per image in MB

# Kindle Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
KINDLE_EMAIL=your_kindle@kindle.com

# Set to False if you want to try without proxies
USE_PROXY=True